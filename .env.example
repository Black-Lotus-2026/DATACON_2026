# Optional deploy settings. For HTTPS with Caddy, set this to your domain.
SITE_ADDRESS=:80
APP_PORT=8000

# Optional server-side LLM defaults for CLI/offline flows.
# The public web UI also accepts Router URL, API key and model from the site per run.
VSEGPT_API_KEY=sk-XXXXXXXXXXXXXXXX
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_MODEL=openai/gpt-4o-mini
