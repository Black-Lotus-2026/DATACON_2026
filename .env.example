# Optional deploy settings. For HTTPS with Caddy, set this to your domain.
SITE_ADDRESS=:80
APP_PORT=8000

# Optional VseGPT settings for the legacy checker/multi-agent flows.
VSEGPT_API_KEY=sk-XXXXXXXXXXXXXXXX
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1
VSEGPT_MODEL=openai/gpt-4o-mini

# Optional OpenAI-compatible settings for datacon_agent CLI/offline benchmark runs.
# OpenRouter example:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4.1
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXX
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_REVIEW_MODEL=gpt-4.1

# Optional local proxy for regions where direct provider access is unstable.
# Leave empty when VPN works as a system tunnel.
# HTTPS_PROXY=socks5h://127.0.0.1:1080
# HTTP_PROXY=socks5h://127.0.0.1:1080
